// ============================================================================
// POS Web v2 — Prisma Schema (camelCase puro, fuente de verdad)
// ============================================================================
// Convenciones:
// - Modelos: PascalCase singular (User, Product, Quote)
// - Campos: camelCase
// - Enums: PascalCase con valores PascalCase
// - BD: Prisma genera columnas/tablas como aparezcan aquí (sin @map)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  ADMIN
  SELLER
  WAREHOUSE
  BILLING
}

enum MovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
  LOSS
}

enum QuoteStatus {
  DRAFT
  SENT
  APPROVED
  PAID
  PREPARING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ShipmentStatus {
  PENDING
  SHIPPED
  IN_TRANSIT
  DELIVERED
  RETURNED
}

enum InvoiceType {
  BOLETA
  FACTURA
}

enum SunatStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
}

// ============================================================================
// 1. USERS & AUTH
// ============================================================================

model User {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(100)
  passwordHash String    @db.VarChar(200)
  role         UserRole  @default(SELLER)
  phone        String?   @db.VarChar(20)
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Self-relation (quién creó a este usuario)
  createdBy User?  @relation("UserCreatedBy", fields: [createdById], references: [id])
  created   User[] @relation("UserCreatedBy")

  // Relations
  activityLogs          ActivityLog[]
  customersCreated      Customer[]
  invoicesCreated       ElectronicInvoice[]
  paymentsCreated       Payment[]            @relation("PaymentCreatedBy")
  paymentsVerified      Payment[]            @relation("PaymentVerifiedBy")
  productsCreated       Product[]            @relation("ProductCreatedBy")
  productsUpdated       Product[]            @relation("ProductUpdatedBy")
  purchasesCreated      Purchase[]
  quotesCreated         Quote[]              @relation("QuoteCreatedBy")
  quotesUpdated         Quote[]              @relation("QuoteUpdatedBy")
  shipmentHistoryEvents ShipmentHistory[]
  shipmentsCreated      Shipment[]           @relation("ShipmentCreatedBy")
  shipmentsUpdated      Shipment[]           @relation("ShipmentUpdatedBy")
  stockMovements        StockMovement[]

  @@index([email])
  @@index([role])
}

model Permission {
  id        Int      @id @default(autoincrement())
  role      UserRole
  module    String   @db.VarChar(50)
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)

  @@unique([role, module])
}

// ============================================================================
// 2. PRODUCTS
// ============================================================================

model ProductCategory {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  parentId     Int?
  description  String?  @db.VarChar(500)
  imageUrl     String?  @db.VarChar(500)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  // Self-relation (subcategorías)
  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")

  products Product[]
}

model Product {
  id             String   @id @default(uuid())
  sku            String?  @unique @db.VarChar(50)
  barcode        String?  @db.VarChar(50)
  name           String   @db.VarChar(200)
  description    String?
  categoryId     Int?
  unit           String   @default("Unid") @db.VarChar(20)
  packSize       Decimal  @default(1) @db.Decimal(10, 4)
  costPrice      Decimal  @default(0) @db.Decimal(10, 2)
  retailPrice    Decimal  @default(0) @db.Decimal(10, 2)
  wholesalePrice Decimal  @default(0) @db.Decimal(10, 2)
  taxRate        Decimal  @default(0.18) @db.Decimal(6, 4)
  isTaxExempt    Boolean  @default(false)
  mainImageUrl   String?  @db.VarChar(500)
  isFeatured     Boolean  @default(false)
  isPublished    Boolean  @default(true)
  isActive       Boolean  @default(true)
  notes          String?  @db.VarChar(500)
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category       ProductCategory?  @relation(fields: [categoryId], references: [id])
  createdBy      User?             @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy      User?             @relation("ProductUpdatedBy", fields: [updatedById], references: [id])
  images         ProductImage[]
  suppliers      SupplierProduct[]
  stock          Stock?
  stockMovements StockMovement[]
  purchaseItems  PurchaseItem[]
  quoteItems     QuoteItem[]

  @@index([sku])
  @@index([barcode])
  @@index([categoryId])
  @@index([isActive, isPublished])
}

model ProductImage {
  id           Int      @id @default(autoincrement())
  productId    String
  imageUrl     String   @db.VarChar(500)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================================================
// 3. SUPPLIERS
// ============================================================================

model Supplier {
  id          String   @id @default(uuid())
  name        String   @db.VarChar(200)
  ruc         String?  @db.VarChar(20)
  contactName String?  @db.VarChar(100)
  phone       String?  @db.VarChar(30)
  email       String?  @db.VarChar(100)
  address     String?  @db.VarChar(300)
  notes       String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products  SupplierProduct[]
  purchases Purchase[]
}

model SupplierProduct {
  id          Int      @id @default(autoincrement())
  supplierId  String
  productId   String
  costPrice   Decimal  @db.Decimal(10, 2)
  isPreferred Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
}

// ============================================================================
// 4. STOCK
// ============================================================================

model Stock {
  id          Int      @id @default(autoincrement())
  productId   String   @unique
  quantity    Decimal  @default(0) @db.Decimal(12, 4)
  reservedQty Decimal  @default(0) @db.Decimal(12, 4)
  avgCost     Decimal  @default(0) @db.Decimal(10, 2)
  minStock    Decimal  @default(0) @db.Decimal(12, 4)
  updatedAt   DateTime @default(now()) @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model StockMovement {
  id           String       @id @default(uuid())
  productId    String
  movementType MovementType
  quantity     Decimal      @db.Decimal(12, 4)
  qtyBefore    Decimal      @default(0) @db.Decimal(12, 4)
  qtyAfter     Decimal      @default(0) @db.Decimal(12, 4)
  unitCost     Decimal      @default(0) @db.Decimal(10, 2)
  documentRef  String?      @db.VarChar(50)
  notes        String?      @db.VarChar(500)
  createdById  String?
  createdAt    DateTime     @default(now())

  product   Product @relation(fields: [productId], references: [id])
  createdBy User?   @relation(fields: [createdById], references: [id])

  @@index([productId])
  @@index([movementType])
  @@index([createdAt])
}

// ============================================================================
// 5. PURCHASES
// ============================================================================

model Purchase {
  id              String   @id @default(uuid())
  documentNumber  String   @unique @db.VarChar(50)
  supplierId      String
  purchaseDate    DateTime @default(now()) @db.Date
  subtotal        Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal  @default(0) @db.Decimal(12, 2)
  supplierInvoice String?  @db.VarChar(50)
  notes           String?  @db.VarChar(500)
  isCompleted     Boolean  @default(false)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  supplier  Supplier       @relation(fields: [supplierId], references: [id])
  createdBy User?          @relation(fields: [createdById], references: [id])
  items     PurchaseItem[]

  @@index([supplierId])
  @@index([purchaseDate])
}

model PurchaseItem {
  id           Int     @id @default(autoincrement())
  purchaseId   String
  productId    String
  quantity     Decimal @db.Decimal(12, 4)
  unitCost     Decimal @db.Decimal(10, 2)
  previousCost Decimal @default(0) @db.Decimal(10, 2)
  totalCost    Decimal @db.Decimal(12, 2)
  taxRate      Decimal @default(0) @db.Decimal(6, 4)
  taxAmount    Decimal @default(0) @db.Decimal(10, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

// ============================================================================
// 6. CUSTOMERS
// ============================================================================

model Customer {
  id             String   @id @default(uuid())
  name           String   @db.VarChar(100)
  phone          String?  @db.VarChar(30)
  phoneAlt       String?  @db.VarChar(30)
  email          String?  @db.VarChar(100)
  address        String?  @db.VarChar(300)
  district       String?  @db.VarChar(100)
  city           String?  @db.VarChar(100)
  region         String?  @db.VarChar(100)
  documentType   String?  @default("DNI") @db.VarChar(10)
  documentNumber String?  @db.VarChar(20)
  notes          String?  @db.VarChar(500)
  isActive       Boolean  @default(true)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  createdBy User?   @relation(fields: [createdById], references: [id])
  quotes    Quote[]

  @@index([name])
  @@index([phone])
  @@index([documentNumber])
}

// ============================================================================
// 7. QUOTES (COTIZACIONES)
// ============================================================================

model Quote {
  id               String      @id @default(uuid())
  quoteNumber      String      @unique @db.VarChar(20)
  customerId       String?
  // Snapshot de datos del cliente al momento de la cotización
  customerName     String?     @db.VarChar(100)
  customerPhone    String?     @db.VarChar(30)
  status           QuoteStatus @default(DRAFT)
  // Dirección de envío (puede diferir de la del cliente)
  shippingAddress  String?     @db.VarChar(300)
  shippingDistrict String?     @db.VarChar(100)
  shippingCity     String?     @db.VarChar(100)
  shippingRegion   String?     @db.VarChar(100)
  subtotal         Decimal     @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal     @default(0) @db.Decimal(10, 2)
  shippingCost     Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal     @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal     @default(0) @db.Decimal(12, 2)
  notes            String?     @db.VarChar(1000)
  customerNotes    String?     @db.VarChar(1000)
  validUntil       DateTime?   @db.Date
  createdById      String
  updatedById      String?
  approvedAt       DateTime?
  paidAt           DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  cancelledAt      DateTime?
  cancelledReason  String?     @db.VarChar(500)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  customer  Customer?           @relation(fields: [customerId], references: [id])
  createdBy User                @relation("QuoteCreatedBy", fields: [createdById], references: [id])
  updatedBy User?               @relation("QuoteUpdatedBy", fields: [updatedById], references: [id])
  items     QuoteItem[]
  payments  Payment[]
  shipment  Shipment?
  invoices  ElectronicInvoice[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model QuoteItem {
  id             Int     @id @default(autoincrement())
  quoteId        String
  productId      String
  // Snapshot del producto al momento de cotizar
  productName    String  @db.VarChar(200)
  productSku     String? @db.VarChar(50)
  unit           String  @db.VarChar(20)
  quantity       Decimal @db.Decimal(12, 4)
  unitPrice      Decimal @db.Decimal(10, 2)
  costPrice      Decimal @default(0) @db.Decimal(10, 2)
  discountPct    Decimal @default(0) @db.Decimal(6, 4)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  taxRate        Decimal @default(0.18) @db.Decimal(6, 4)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(12, 2)
  notes          String? @db.VarChar(200)

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ============================================================================
// 8. PAYMENTS
// ============================================================================

model PaymentMethod {
  id           Int     @id @default(autoincrement())
  name         String  @db.VarChar(50)
  type         String  @default("digital") @db.VarChar(20)
  accountInfo  String? @db.VarChar(200)
  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  payments Payment[]
}

model Payment {
  id              String        @id @default(uuid())
  quoteId         String
  paymentMethodId Int
  amount          Decimal       @db.Decimal(10, 2)
  reference       String?       @db.VarChar(100)
  voucherUrl      String?       @db.VarChar(500)
  notes           String?       @db.VarChar(500)
  status          PaymentStatus @default(PENDING)
  verifiedById    String?
  verifiedAt      DateTime?
  rejectedReason  String?       @db.VarChar(500)
  createdById     String?
  createdAt       DateTime      @default(now())

  quote         Quote         @relation(fields: [quoteId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
  verifiedBy    User?         @relation("PaymentVerifiedBy", fields: [verifiedById], references: [id])
  createdBy     User?         @relation("PaymentCreatedBy", fields: [createdById], references: [id])

  @@index([quoteId])
  @@index([status])
}

// ============================================================================
// 9. SHIPMENTS (DESPACHOS)
// ============================================================================

model Courier {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(100)
  phone       String? @db.VarChar(30)
  trackingUrl String? @db.VarChar(200)
  isActive    Boolean @default(true)

  shipments Shipment[]
}

model Shipment {
  id                String         @id @default(uuid())
  quoteId           String         @unique
  courierId         Int?
  trackingNumber    String?        @db.VarChar(100)
  status            ShipmentStatus @default(PENDING)
  deliveryAddress   String?        @db.VarChar(300)
  deliveryDistrict  String?        @db.VarChar(100)
  deliveryCity      String?        @db.VarChar(100)
  deliveryRegion    String?        @db.VarChar(100)
  recipientName     String?        @db.VarChar(100)
  recipientPhone    String?        @db.VarChar(30)
  recipientDocument String?        @db.VarChar(20)
  shippedAt         DateTime?
  estimatedDelivery DateTime?      @db.Date
  deliveredAt       DateTime?
  shippingCost      Decimal        @default(0) @db.Decimal(10, 2)
  notes             String?        @db.VarChar(500)
  createdById       String?
  updatedById       String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  quote     Quote             @relation(fields: [quoteId], references: [id])
  courier   Courier?          @relation(fields: [courierId], references: [id])
  createdBy User?             @relation("ShipmentCreatedBy", fields: [createdById], references: [id])
  updatedBy User?             @relation("ShipmentUpdatedBy", fields: [updatedById], references: [id])
  history   ShipmentHistory[]

  @@index([trackingNumber])
  @@index([status])
}

model ShipmentHistory {
  id          Int            @id @default(autoincrement())
  shipmentId  String
  status      ShipmentStatus
  notes       String?        @db.VarChar(500)
  createdById String?
  createdAt   DateTime       @default(now())

  shipment  Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  createdBy User?    @relation(fields: [createdById], references: [id])
}

// ============================================================================
// 10. BILLING (SUNAT)
// ============================================================================

model ElectronicInvoice {
  id              String      @id @default(uuid())
  quoteId         String
  invoiceType     InvoiceType @default(BOLETA)
  series          String      @db.VarChar(10)
  correlative     Int
  // invoiceNumber se calcula en código al crear el registro (ej: B001-00000001)
  invoiceNumber   String?     @db.VarChar(20)
  issuerRuc       String      @db.VarChar(20)
  issuerName      String      @db.VarChar(200)
  customerDocType String      @default("DNI") @db.VarChar(10)
  customerDoc     String      @db.VarChar(20)
  customerName    String      @db.VarChar(200)
  customerAddress String?     @db.VarChar(300)
  subtotal        Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  invoiceDate     DateTime    @default(now()) @db.Date
  sunatStatus     SunatStatus @default(PENDING)
  sunatResponse   String?
  xmlFileUrl      String?     @db.VarChar(500)
  pdfFileUrl      String?     @db.VarChar(500)
  hashCode        String?     @db.VarChar(200)
  createdById     String?
  createdAt       DateTime    @default(now())

  quote     Quote @relation(fields: [quoteId], references: [id])
  createdBy User? @relation(fields: [createdById], references: [id])

  @@unique([series, correlative])
  @@index([invoiceNumber])
  @@index([customerDoc])
}

model InvoiceSequence {
  series      String      @id @db.VarChar(10)
  invoiceType InvoiceType
  lastNumber  Int         @default(0)
  isActive    Boolean     @default(true)
}

// ============================================================================
// 11. SYSTEM
// ============================================================================

model SystemConfig {
  key         String   @id @db.VarChar(50)
  value       String
  description String?  @db.VarChar(200)
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   @db.VarChar(50)
  module    String   @db.VarChar(50)
  recordId  String?  @db.VarChar(100)
  oldValues Json?
  newValues Json?
  ipAddress String?  @db.VarChar(45)
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([module])
  @@index([createdAt])
}

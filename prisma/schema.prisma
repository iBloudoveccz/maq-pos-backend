// ============================================================
// SCHEMA PRISMA — SISTEMA POS WEB
// App 1: Tienda Web (E-commerce)
// App 2: Panel Admin (reemplaza POS S12)
// Mercado: Perú · IGV 18% · SUNAT
// Convención: PascalCase modelos · camelCase campos · MAYÚSCULAS enums
// 29 modelos | 12 enums
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN     // Acceso total al sistema
  SELLER    // Ventas, cotizaciones, clientes
  WAREHOUSE // Inventario, compras, despachos
  BILLING   // Comprobantes electrónicos SUNAT
  CASHIER   // Solo operación de caja / turno
}

enum MovementType {
  PURCHASE     // Entrada por compra a proveedor
  SALE         // Salida por venta
  RETURN       // Devolución de cliente (entrada)
  ADJUSTMENT   // Ajuste manual de inventario
  STOCKTAKING  // Ajuste por inventario físico
  TRANSFER_IN  // Traslado recibido de otro almacén
  TRANSFER_OUT // Traslado enviado a otro almacén
  OWN_USE      // Retiro para uso interno
  CONVERT_IN   // Conversión producto destino
  CONVERT_OUT  // Conversión producto origen
  LOSS         // Merma / pérdida
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum SaleStatus {
  VALID     // Sxyn=0
  CANCELLED // Sxyn=1 — nunca se elimina físicamente
}

enum ShiftStatus {
  OPEN
  CLOSED
}

enum InvoiceType {
  BOLETA
  FACTURA
}

enum SunatStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum LoyaltyTxType {
  SALE
  CHARGE
  REDEEM
  ADJUST
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum StocktakingStatus {
  IN_PROGRESS
  COMPLETED
}

enum StoreOrderStatus {
  PENDING_PAYMENT
  PAYMENT_RECEIVED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum StorePaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

// ============================================================
// 1. USUARIOS / OPERADORES
// S12: Operator (Rycode) + Ls_Operator (MinDiscount, MaxDiscount)
// ============================================================

model User {
  id           String    @id @default(uuid())
  code         String    @unique
  name         String
  email        String?   @unique
  passwordHash String
  role         UserRole  @default(SELLER)
  phone        String?
  birthDate    DateTime?
  startDate    DateTime?
  isActive     Boolean   @default(true)
  warehouseId  String?
  minDiscount  Decimal?  @db.Decimal(5, 2)
  maxDiscount  Decimal?  @db.Decimal(5, 2)
  lastLoginAt  DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  warehouse         Warehouse?      @relation("WarehouseUsers", fields: [warehouseId], references: [id])
  createdBy         User?           @relation("CreatedByUser", fields: [createdById], references: [id])
  usersCreated      User[]          @relation("CreatedByUser")
  salesAsCashier    Sale[]          @relation("SaleCashier")
  purchasesCreated  Purchase[]
  stockMovements    StockMovement[]
  shiftsOpened      CashShift[]
  cashBookEntries   CashBookEntry[]
  stocktakings      Stocktaking[]
  transfersCreated  StockTransfer[] @relation("TransferCreatedBy")
  transfersReceived StockTransfer[] @relation("TransferReceivedBy")
  activityLogs      ActivityLog[]
}

// ============================================================
// 2. ALMACENES
// S12: Store (Ckcode, Name, ForBranch)
// ============================================================

model Warehouse {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isBranch  Boolean  @default(false)
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users          User[]          @relation("WarehouseUsers")
  terminals      Terminal[]
  stock          Stock[]
  stockMovements StockMovement[]
  purchases      Purchase[]
  stocktakings   Stocktaking[]
  transfersFrom  StockTransfer[] @relation("TransferFrom")
  transfersTo    StockTransfer[] @relation("TransferTo")
}

// ============================================================
// 3. TERMINALES POS
// S12: Posname (Posid, PosCkSet, PosGroup)
// ============================================================

model Terminal {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String?
  warehouseId String
  groupCode   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  warehouse Warehouse   @relation(fields: [warehouseId], references: [id])
  shifts    CashShift[]
  sales     Sale[]
}

// ============================================================
// 4. CATEGORÍAS
// S12: B_Category + q_GroupSet
// ============================================================

model Category {
  id           Int      @id @default(autoincrement())
  code         String?  @unique
  name         String
  parentId     Int?
  description  String?
  imageUrl     String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
}

// ============================================================
// 5. PRODUCTOS
// S12: Goods (Cpcode, pm, dw, Spec, PNotes, jhj, lsj, pfj/2/3, Hyj, Vip2-5, zzsl)
// ============================================================

model Product {
  id          String  @id @default(uuid())
  sku         String  @unique
  barcode     String?
  name        String
  description String?
  spec        String?
  unit        String  @default("Unid")
  packSize    Decimal @default(1) @db.Decimal(10, 4)
  categoryId  Int?
  notes       String?

  costPrice       Decimal @default(0) @db.Decimal(10, 2)
  retailPrice     Decimal @default(0) @db.Decimal(10, 2)
  wholesalePrice1 Decimal @default(0) @db.Decimal(10, 2)
  wholesalePrice2 Decimal @default(0) @db.Decimal(10, 2)
  wholesalePrice3 Decimal @default(0) @db.Decimal(10, 2)
  memberPrice     Decimal @default(0) @db.Decimal(10, 2)
  vipPrice2       Decimal @default(0) @db.Decimal(10, 2)
  vipPrice3       Decimal @default(0) @db.Decimal(10, 2)
  vipPrice4       Decimal @default(0) @db.Decimal(10, 2)
  vipPrice5       Decimal @default(0) @db.Decimal(10, 2)

  taxRate     Decimal @default(0.18) @db.Decimal(6, 4)
  isTaxExempt Boolean @default(false)

  mainImageUrl String?
  isFeatured   Boolean @default(false)
  isPublished  Boolean @default(true)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category           Category?           @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  stock              Stock[]
  supplierProducts   SupplierProduct[]
  saleItems          SaleItem[]
  purchaseItems      PurchaseItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockMovements     StockMovement[]
  stocktakingItems   StocktakingItem[]
  transferItems      StockTransferItem[]
  storeOrderItems    StoreOrderItem[]
}

model ProductImage {
  id           Int      @id @default(autoincrement())
  productId    String
  imageUrl     String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ============================================================
// 6. STOCK POR ALMACÉN
// S12: L_Stocks (Cpcode, Ckcode, Kcsl, Kcje, jhj, Batch)
// ============================================================

model Stock {
  id          Int      @id @default(autoincrement())
  productId   String
  warehouseId String
  quantity    Decimal  @default(0) @db.Decimal(12, 4)
  stockValue  Decimal  @default(0) @db.Decimal(12, 2)
  avgCost     Decimal  @default(0) @db.Decimal(10, 2)
  minStock    Decimal  @default(0) @db.Decimal(12, 4)
  batchNumber String?
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

// ============================================================
// 7. MOVIMIENTOS DE INVENTARIO
// S12: L_kcinout (CKCODE, FOLI, SLIN, SLOUT, JCSL, jhj, Jcje, Text, dotime)
// ============================================================

model StockMovement {
  id           String       @id @default(uuid())
  productId    String
  warehouseId  String
  movementType MovementType
  quantityIn   Decimal      @default(0) @db.Decimal(12, 4)
  quantityOut  Decimal      @default(0) @db.Decimal(12, 4)
  balanceQty   Decimal      @default(0) @db.Decimal(12, 4)
  unitCost     Decimal      @default(0) @db.Decimal(10, 2)
  totalValue   Decimal      @default(0) @db.Decimal(12, 2)
  documentRef  String?
  batchNumber  String?
  notes        String?
  createdById  String?
  createdAt    DateTime     @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  createdBy User?     @relation(fields: [createdById], references: [id])
}

// ============================================================
// 8. PROVEEDORES
// S12: Ghscode implícito en BL_Purchase + GoodsVendor
// ============================================================

model Supplier {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  ruc         String?
  contactName String?
  phone       String?
  email       String?
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products       SupplierProduct[]
  purchases      Purchase[]
  purchaseOrders PurchaseOrder[]
  payments       SupplierPayment[]
}

model SupplierProduct {
  id          Int      @id @default(autoincrement())
  supplierId  String
  productId   String
  costPrice   Decimal  @db.Decimal(10, 2)
  isPreferred Boolean  @default(false)
  updatedAt   DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([supplierId, productId])
}

// ============================================================
// 9. COMPRAS DIRECTAS
// S12: BL_Purchase + DT_Purchase
// Folio: PH{AA}{MM}{DD}{Posid}{seq}
// ============================================================

model Purchase {
  id              String         @id @default(uuid())
  documentNumber  String         @unique
  supplierId      String
  warehouseId     String
  purchaseOrderId String?
  purchaseDate    DateTime       @default(now())
  subtotal        Decimal        @default(0) @db.Decimal(12, 2)
  taxRate         Decimal        @default(0) @db.Decimal(6, 4)
  taxAmount       Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount     Decimal        @default(0) @db.Decimal(12, 2)
  amountPaid      Decimal        @default(0) @db.Decimal(12, 2)
  status          PurchaseStatus @default(PENDING)
  notes           String?
  supplierInvoice String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  warehouse     Warehouse       @relation(fields: [warehouseId], references: [id])
  purchaseOrder PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  createdBy     User?           @relation(fields: [createdById], references: [id])
  items         PurchaseItem[]
  payments      SupplierPayment[]
}

model PurchaseItem {
  id           Int     @id @default(autoincrement())
  purchaseId   String
  productId    String
  quantity     Decimal @db.Decimal(12, 4)
  unitCost     Decimal @db.Decimal(10, 2)
  previousCost Decimal @default(0) @db.Decimal(10, 2)
  retailPrice  Decimal @default(0) @db.Decimal(10, 2)
  totalCost    Decimal @db.Decimal(12, 2)
  taxRate      Decimal @default(0) @db.Decimal(6, 4)
  taxAmount    Decimal @default(0) @db.Decimal(10, 2)
  batchNumber  String?
  notes        String?

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

// ============================================================
// 10. ÓRDENES DE COMPRA
// S12: BL_PurchaseOrders + DT_PurchaseOrders
// Folio: PO{AA}{MM}{DD}{Posid}{seq}
// ============================================================

model PurchaseOrder {
  id             String         @id @default(uuid())
  documentNumber String         @unique
  supplierId     String
  orderDate      DateTime       @default(now())
  expectedDate   DateTime?
  receivedDate   DateTime?
  subtotal       Decimal        @default(0) @db.Decimal(12, 2)
  taxAmount      Decimal        @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal        @default(0) @db.Decimal(12, 2)
  amountPaid     Decimal        @default(0) @db.Decimal(12, 2)
  isReceived     Boolean        @default(false)
  status         PurchaseStatus @default(PENDING)
  notes          String?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  items     PurchaseOrderItem[]
  purchases Purchase[]
}

model PurchaseOrderItem {
  id           Int     @id @default(autoincrement())
  orderId      String
  productId    String
  requestedQty Decimal @db.Decimal(12, 4)
  receivedQty  Decimal @default(0) @db.Decimal(12, 4)
  stockAtOrder Decimal @default(0) @db.Decimal(12, 4)
  unitCost     Decimal @db.Decimal(10, 2)
  previousCost Decimal @default(0) @db.Decimal(10, 2)
  retailPrice  Decimal @default(0) @db.Decimal(10, 2)
  totalCost    Decimal @db.Decimal(12, 2)
  taxRate      Decimal @default(0) @db.Decimal(6, 4)
  taxAmount    Decimal @default(0) @db.Decimal(10, 2)
  notes        String?

  order   PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])
}

// ============================================================
// 11. PAGOS A PROVEEDORES
// S12: PayRec (Code, Payfoli, LastUnPay, Pay, NewUnPay)
// ============================================================

model SupplierPayment {
  id            Int      @id @default(autoincrement())
  supplierId    String
  purchaseId    String
  previousDebt  Decimal  @db.Decimal(12, 2)
  amountPaid    Decimal  @db.Decimal(12, 2)
  remainingDebt Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime @default(now())
  notes         String?

  supplier Supplier @relation(fields: [supplierId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id])
}

// ============================================================
// 12. CLIENTES
// S12: Customer (Khcode) + datos de VipMember
// ============================================================

model Customer {
  id             String   @id @default(uuid())
  code           String?  @unique
  name           String
  phone          String?
  phoneAlt       String?
  email          String?
  address        String?
  district       String?
  city           String?
  region         String?
  documentType   String   @default("DNI")
  documentNumber String?
  birthDate      DateTime?
  sex            String?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  loyaltyCard       LoyaltyCard?
  sales             Sale[]
  storeOrders       StoreOrder[]
  creditCollections CreditCollection[]
}

// ============================================================
// 13. NIVELES VIP
// S12: B_VipType (Lbcode, Name, TheYhType, Zkl, Token, Perfen, PlYear)
// ============================================================

model LoyaltyLevel {
  id                  Int      @id @default(autoincrement())
  code                String   @unique
  name                String
  cardType            Int      @default(2)
  discountFactor      Decimal  @default(1.00) @db.Decimal(5, 2)
  pointsPerSol        Int      @default(1)
  redemptionThreshold Decimal  @default(10) @db.Decimal(10, 2)
  validityYears       Int      @default(0)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())

  cards       LoyaltyCard[]
  chargePlans LoyaltyChargePlan[]
}

// ============================================================
// 14. TARJETAS VIP
// S12: VipMember (Yhkid, Lbcode, isValid, Makedate, Activedate, Enddate)
// ============================================================

model LoyaltyCard {
  id           String    @id @default(uuid())
  cardNumber   String    @unique
  cardSerial   String?
  customerId   String    @unique
  levelId      Int
  balance      Decimal   @default(0) @db.Decimal(12, 2)
  balanceBonus Decimal   @default(0) @db.Decimal(12, 2)
  isActive     Boolean   @default(true)
  pin          String?
  taxId        String?
  size         String?
  notes        String?
  issuedAt     DateTime  @default(now())
  activatedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  customer     Customer             @relation(fields: [customerId], references: [id])
  level        LoyaltyLevel         @relation(fields: [levelId], references: [id])
  transactions LoyaltyTransaction[]
  movements    LoyaltyMovement[]
  charges      LoyaltyCharge[]
  sales        Sale[]
}

// ============================================================
// 15. TRANSACCIONES VIP
// S12: VipRec (Yhkid, Foli, Xsje, Balance, BalanceExtra, Text, VOID)
// ============================================================

model LoyaltyTransaction {
  id                Int           @id @default(autoincrement())
  cardId            String
  documentRef       String?
  transactionType   LoyaltyTxType
  saleAmount        Decimal       @default(0) @db.Decimal(12, 2)
  balanceAfter      Decimal       @default(0) @db.Decimal(12, 2)
  balanceBonusAfter Decimal       @default(0) @db.Decimal(12, 2)
  terminalCode      String?
  isVoid            Boolean       @default(false)
  createdAt         DateTime      @default(now())

  card LoyaltyCard @relation(fields: [cardId], references: [id])
}

// ============================================================
// 16. MOVIMIENTOS DE SALDO VIP
// S12: VipInout (Jein, Jeout, Jecun, billAmt)
// ============================================================

model LoyaltyMovement {
  id             Int           @id @default(autoincrement())
  cardId         String
  documentRef    String?
  amountIn       Decimal       @default(0) @db.Decimal(12, 2)
  amountOut      Decimal       @default(0) @db.Decimal(12, 2)
  runningBalance Decimal       @default(0) @db.Decimal(12, 2)
  saleAmount     Decimal       @default(0) @db.Decimal(12, 2)
  movementType   LoyaltyTxType
  terminalCode   String?
  createdAt      DateTime      @default(now())

  card LoyaltyCard @relation(fields: [cardId], references: [id])
}

// ============================================================
// 17. PLANES DE RECARGA VIP
// S12: B_VipChargeType (ChargeAmount, ExtraAmount, Gift)
// ============================================================

model LoyaltyChargePlan {
  id           Int       @id @default(autoincrement())
  code         String    @unique
  name         String
  chargeAmount Decimal   @db.Decimal(10, 2)
  bonusAmount  Decimal   @default(0) @db.Decimal(10, 2)
  gift         String?
  levelId      Int?
  startsAt     DateTime?
  expiresAt    DateTime?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())

  level   LoyaltyLevel?   @relation(fields: [levelId], references: [id])
  charges LoyaltyCharge[]
}

// ============================================================
// 18. RECARGAS VIP
// S12: L_VipCharge (VipCode, ChargeAmount, ExtraAmount, Paymode)
// ============================================================

model LoyaltyCharge {
  id            Int       @id @default(autoincrement())
  cardId        String
  planId        Int?
  chargeAmount  Decimal   @db.Decimal(10, 2)
  bonusAmount   Decimal   @default(0) @db.Decimal(10, 2)
  paymentMethod String?
  terminalCode  String?
  gift          String?
  createdAt     DateTime  @default(now())

  card LoyaltyCard        @relation(fields: [cardId], references: [id])
  plan LoyaltyChargePlan? @relation(fields: [planId], references: [id])
}

// ============================================================
// 19. MODOS DE PAGO
// S12: B_Paymode (Code, Name, Enabled)
// Códigos Perú: 01=Efectivo, 02=Tarjeta, D1=Plim, D2=Yape
// ============================================================

model PaymentMethod {
  id           Int      @id @default(autoincrement())
  code         String   @unique
  name         String
  type         String   @default("digital")
  accountInfo  String?
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  salePayments  SalePayment[]
  shiftPayments ShiftPayment[]
}

// ============================================================
// 20. TURNOS DE CAJA
// S12: L_gcinfo (gcid, gc, gcdate, gcuser, Posid, Gccode,
//               gcinTime, gcoutTime, Xsje, Lsje, Tax, folicount, Xssl)
// shiftCode formato: "{terminalCode}_{AAMMDD}{HHMMSS}"
// ============================================================

model CashShift {
  id             Int         @id @default(autoincrement())
  shiftNumber    Int
  shiftDate      DateTime
  terminalId     String
  cashierId      String
  shiftCode      String      @unique
  status         ShiftStatus @default(OPEN)
  openedAt       DateTime
  closedAt       DateTime?
  openingCash    Decimal     @default(0) @db.Decimal(12, 2)
  salesTotal     Decimal     @default(0) @db.Decimal(12, 2)
  listPriceTotal Decimal     @default(0) @db.Decimal(12, 2)
  taxTotal       Decimal     @default(0) @db.Decimal(12, 2)
  saleCount      Int         @default(0)
  unitsSold      Decimal     @default(0) @db.Decimal(12, 4)
  cashWithdrawn  Decimal     @default(0) @db.Decimal(12, 2)
  returnAmount   Decimal     @default(0) @db.Decimal(12, 2)
  returnCount    Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  terminal      Terminal       @relation(fields: [terminalId], references: [id])
  cashier       User           @relation(fields: [cashierId], references: [id])
  sales         Sale[]
  shiftPayments ShiftPayment[]
}

// S12: L_gcinfopay (Gcid, PayMode, PayMoney, UpMoney)
model ShiftPayment {
  id              Int     @id @default(autoincrement())
  shiftId         Int
  paymentMethodId Int
  totalCollected  Decimal @db.Decimal(12, 2)
  confirmedAmount Decimal @default(0) @db.Decimal(12, 2)

  shift         CashShift     @relation(fields: [shiftId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

// ============================================================
// 21. LIBRO DE CAJA GENERAL
// S12: L_MoneyInout (ZjXmcode, Jein, Jeout, Jecun, Text, ItemText, doTime)
// Una venta genera múltiples filas (una por modo de pago usado)
// ============================================================

model CashBookEntry {
  id             Int      @id @default(autoincrement())
  accountCode    String   @default("000001")
  entryDate      DateTime
  amountIn       Decimal  @default(0) @db.Decimal(12, 2)
  amountOut      Decimal  @default(0) @db.Decimal(12, 2)
  runningBalance Decimal  @default(0) @db.Decimal(12, 2)
  movementType   String
  description    String?
  documentRef    String?
  terminalCode   String?
  createdById    String?
  isSynced       Boolean  @default(false)
  createdAt      DateTime @default(now())

  createdBy User? @relation(fields: [createdById], references: [id])
}

// ============================================================
// 22. VENTAS
// S12: allSaleBill + allSaleItem + allSalePay
// Folio: {Posid}-{AA}{MM}{DD}{seq}  ej: "09-26040000001"
// REGLA: Las ventas NUNCA se eliminan. Solo se cambia status.
// ============================================================

model Sale {
  id            String     @id @default(uuid())
  saleNumber    String     @unique
  saleDate      DateTime
  saleTime      DateTime
  shiftId       Int?
  terminalId    String?
  cashierId     String?
  customerId    String?
  loyaltyCardId String?
  taxId         String?
  invoiceSeries String?
  subtotal      Decimal    @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal    @default(0) @db.Decimal(12, 2)
  discountAmount Decimal   @default(0) @db.Decimal(12, 2)
  shippingCost  Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal    @default(0) @db.Decimal(12, 2)
  status        SaleStatus @default(VALID)
  refundFromId  String?
  notes         String?
  isSynced      Boolean    @default(false)
  createdAt     DateTime   @default(now())

  shift        CashShift?        @relation(fields: [shiftId], references: [id])
  terminal     Terminal?         @relation(fields: [terminalId], references: [id])
  cashier      User?             @relation("SaleCashier", fields: [cashierId], references: [id])
  customer     Customer?         @relation(fields: [customerId], references: [id])
  loyaltyCard  LoyaltyCard?      @relation(fields: [loyaltyCardId], references: [id])
  items        SaleItem[]
  payments     SalePayment[]
  invoice      ElectronicInvoice?
  refundFrom   Sale?             @relation("SaleRefunds", fields: [refundFromId], references: [id])
  refunds      Sale[]            @relation("SaleRefunds")
  creditRecord CreditCollection?
  storeOrder   StoreOrder?       @relation("StoreOrderSale")
}

// S12: allSaleItem (FOLI, Cpcode, Pm, Dw, XSSL, LSJ, JHJ, XSJE, zkl, yhkzkl, TaxRate, Tax)
model SaleItem {
  id              Int     @id @default(autoincrement())
  saleId          String
  productId       String
  productName     String
  unit            String
  barcode         String?
  quantity        Decimal @db.Decimal(12, 4)
  unitPrice       Decimal @db.Decimal(10, 2)
  costPrice       Decimal @db.Decimal(10, 2)
  totalAmount     Decimal @db.Decimal(12, 2)
  discountAmount  Decimal @default(0) @db.Decimal(10, 2)
  loyaltyDiscount Decimal @default(0) @db.Decimal(10, 2)
  taxRate         Decimal @default(0.18) @db.Decimal(6, 4)
  taxAmount       Decimal @default(0) @db.Decimal(10, 2)
  amountBeforeTax Decimal @default(0) @db.Decimal(12, 2)
  isPromotional   Boolean @default(false)
  countsStats     Boolean @default(true)
  warehouseId     String?

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// S12: allSalePay (foli, PayMode, Bank, PayMoney, PaidMoney, ChangeMoney)
model SalePayment {
  id              Int      @id @default(autoincrement())
  saleId          String
  paymentMethodId Int
  bankName        String?
  amountReceived  Decimal  @db.Decimal(12, 2)
  amountApplied   Decimal  @db.Decimal(12, 2)
  changeAmount    Decimal  @default(0) @db.Decimal(10, 2)
  authCode        String?
  paidAt          DateTime @default(now())

  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

// ============================================================
// 23. FACTURACIÓN ELECTRÓNICA SUNAT
// S12: ElecPeruInvoice
// ============================================================

model ElectronicInvoice {
  id              String      @id @default(uuid())
  saleId          String      @unique
  invoiceType     InvoiceType
  series          String
  correlative     Int
  invoiceNumber   String      @unique
  issuerRuc       String
  issuerName      String
  customerDocType String      @default("DNI")
  customerDoc     String
  customerName    String
  customerAddress String?
  subtotal        Decimal     @db.Decimal(12, 2)
  taxAmount       Decimal     @db.Decimal(10, 2)
  totalAmount     Decimal     @db.Decimal(12, 2)
  invoiceDate     DateTime    @default(now())
  sunatStatus     SunatStatus @default(PENDING)
  sunatResponse   String?
  xmlFileUrl      String?
  pdfFileUrl      String?
  hashCode        String?
  createdById     String?
  createdAt       DateTime    @default(now())

  sale Sale @relation(fields: [saleId], references: [id])

  @@unique([series, correlative])
}

model InvoiceSequence {
  series      String      @id
  invoiceType InvoiceType
  lastNumber  Int         @default(0)
  isActive    Boolean     @default(true)
}

// ============================================================
// 24. TOMA DE INVENTARIO FÍSICO
// S12: BL_Stocktaking + DT_Stocktaking
// Folio: IC{AA}{MM}{DD}{seq}  ej: IC25041402001
// Al cerrar: Stock.quantity ← countedQty por cada producto
// ============================================================

model Stocktaking {
  id             String            @id @default(uuid())
  documentNumber String            @unique
  warehouseId    String
  countDate      DateTime
  status         StocktakingStatus @default(IN_PROGRESS)
  notes          String?
  createdById    String?
  closedAt       DateTime?
  createdAt      DateTime          @default(now())

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  createdBy User?            @relation(fields: [createdById], references: [id])
  items     StocktakingItem[]
}

model StocktakingItem {
  id            Int     @id @default(autoincrement())
  stocktakingId String
  productId     String
  countedQty    Decimal @db.Decimal(12, 4)
  systemQty     Decimal @db.Decimal(12, 4)
  unitCost      Decimal @db.Decimal(10, 2)
  retailPrice   Decimal @default(0) @db.Decimal(10, 2)
  batchNumber   String?
  notes         String?

  stocktaking Stocktaking @relation(fields: [stocktakingId], references: [id], onDelete: Cascade)
  product     Product     @relation(fields: [productId], references: [id])
}

// ============================================================
// 25. TRASLADOS ENTRE ALMACENES
// S12: Bl_Allocation + Dt_Allocation
// Genera SLOUT en almacén origen y SLIN en almacén destino
// ============================================================

model StockTransfer {
  id              String         @id @default(uuid())
  documentNumber  String         @unique
  fromWarehouseId String
  toWarehouseId   String
  transferDate    DateTime       @default(now())
  status          TransferStatus @default(PENDING)
  totalValue      Decimal        @default(0) @db.Decimal(12, 2)
  isReceived      Boolean        @default(false)
  receivedAt      DateTime?
  receivedById    String?
  createdById     String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  fromWarehouse Warehouse          @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse          @relation("TransferTo", fields: [toWarehouseId], references: [id])
  createdBy     User?              @relation("TransferCreatedBy", fields: [createdById], references: [id])
  receivedBy    User?              @relation("TransferReceivedBy", fields: [receivedById], references: [id])
  items         StockTransferItem[]
}

model StockTransferItem {
  id          Int     @id @default(autoincrement())
  transferId  String
  productId   String
  sentQty     Decimal @db.Decimal(12, 4)
  receivedQty Decimal @default(0) @db.Decimal(12, 4)
  unitCost    Decimal @db.Decimal(10, 2)
  batchNumber String?
  notes       String?

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])
}

// ============================================================
// 26. COBROS A CLIENTES CON CRÉDITO
// S12: Bl_Proceeds (Skfoli, Oldjy, Paid, Newje, Khcode)
// ============================================================

model CreditCollection {
  id             String   @id @default(uuid())
  documentNumber String   @unique
  customerId     String
  saleId         String?  @unique
  previousDebt   Decimal  @db.Decimal(12, 2)
  amountPaid     Decimal  @db.Decimal(12, 2)
  remainingDebt  Decimal  @db.Decimal(12, 2)
  notes          String?
  isVoid         Boolean  @default(false)
  createdAt      DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  sale     Sale?    @relation(fields: [saleId], references: [id])
}

// ============================================================
// 27. TIENDA WEB — PEDIDOS ONLINE (App 1)
// El cliente compra desde el catálogo web.
// Cuando el admin procesa → se crea Sale vinculado (saleId).
// ============================================================

model StoreOrder {
  id               String           @id @default(uuid())
  orderNumber      String           @unique
  customerId       String?
  customerName     String
  customerPhone    String
  customerEmail    String?
  shippingAddress  String?
  shippingDistrict String?
  shippingCity     String?
  shippingRegion   String?
  subtotal         Decimal          @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal          @default(0) @db.Decimal(10, 2)
  shippingCost     Decimal          @default(0) @db.Decimal(10, 2)
  discountAmount   Decimal          @default(0) @db.Decimal(10, 2)
  totalAmount      Decimal          @default(0) @db.Decimal(12, 2)
  status           StoreOrderStatus @default(PENDING_PAYMENT)
  trackingNumber   String?
  notes            String?
  saleId           String?          @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  customer Customer?       @relation(fields: [customerId], references: [id])
  sale     Sale?           @relation("StoreOrderSale", fields: [saleId], references: [id])
  items    StoreOrderItem[]
  payments StorePayment[]
}

model StoreOrderItem {
  id          Int     @id @default(autoincrement())
  orderId     String
  productId   String
  productName String
  imageUrl    String?
  unit        String
  quantity    Decimal @db.Decimal(12, 4)
  unitPrice   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(12, 2)
  notes       String?

  order   StoreOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])
}

model StorePayment {
  id             Int                @id @default(autoincrement())
  orderId        String
  methodName     String
  amount         Decimal            @db.Decimal(10, 2)
  reference      String?
  voucherUrl     String?
  status         StorePaymentStatus @default(PENDING)
  verifiedById   String?
  verifiedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime           @default(now())

  order StoreOrder @relation(fields: [orderId], references: [id])
}

// ============================================================
// 28. CONFIGURACIÓN DEL SISTEMA
// S12: Sysinfo
// ============================================================

model SystemConfig {
  key         String   @id
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

// ============================================================
// 29. LOG DE AUDITORÍA
// S12: Sylog
// ============================================================

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  module    String
  recordId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
